# LumaRijschool v8 — local development environment template
# Copy to .env for local development.
# Do not use these placeholder values in production.

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXTAUTH_URL=https://lumatheorie.nl
NEXTAUTH_SECRET=replace-with-a-random-32-byte-secret
SHOW_DEMO_CREDENTIALS=true

# ─── Database / Prisma ──────────────────────────────────
POSTGRES_USER=luma
POSTGRES_PASSWORD=change-me-local
POSTGRES_DB=lumarijschool
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://luma:change-me-local@localhost:5432/lumarijschool?schema=public
BASELINE_EXISTING_DB=false

# ─── Redis / WebSocket ──────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
WS_PORT=3001

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_PRICE_WEEK=price_replace_week
STRIPE_PRICE_MONTH=price_replace_month

# ─── SMTP Email ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LumaRijschool <noreply@example.local>"

# ─── Backups / uploads ──────────────────────────────────
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Optional S3 backup upload support
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=

# Optional AI SDK config:
# The z-ai-web-dev-sdk may also require a local .z-ai-config file depending on your environment.
