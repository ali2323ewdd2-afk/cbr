# LumaRijschool v8 — production Docker Compose environment template
#
# Deployment usage:
#   cp .env.production.example .env.production
#   edit .env.production and replace every CHANGE_ME_* value
#   docker compose --env-file .env.production config
#   docker compose up -d --build
#
# SECURITY:
# - Never commit .env.production with real secrets.
# - Use strong unique production values.
# - Keep NEXTAUTH_URL exactly equal to the public HTTPS origin.

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000
NEXTAUTH_URL=https://lumatheorie.nl
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_32_BYTE_OR_LONGER_SECRET
SHOW_DEMO_CREDENTIALS=false

# ─── PostgreSQL / Prisma ────────────────────────────────
# docker-compose.yml builds DATABASE_URL internally from POSTGRES_* for app/ws.
POSTGRES_USER=luma
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_DB=lumarijschool
POSTGRES_HOST=postgres

# Optional override for non-Compose/manual deployments.
DATABASE_URL=postgresql://luma:CHANGE_ME_STRONG_DATABASE_PASSWORD@postgres:5432/lumarijschool?schema=public

# Set to true once only when deploying to a pre-existing database that was created before Prisma migrations were introduced.
BASELINE_EXISTING_DB=false

# ─── Redis / WebSocket service ───────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
WS_PORT=3001

# ─── Stripe payments ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_PRICE_WEEK=price_CHANGE_ME_WEEK
STRIPE_PRICE_MONTH=price_CHANGE_ME_MONTH

# ─── SMTP email ──────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_SMTP_USERNAME
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="Luma Theorie <noreply@lumatheorie.nl>"

# ─── Backups / uploads ──────────────────────────────────
# In Docker Compose, /app/backups is backed by the app_backups volume.
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30

# Optional S3 backup upload support. Leave blank to disable.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=

# Optional AI SDK config:
# If your AI tutor provider requires z-ai-web-dev-sdk configuration,
# mount/provide .z-ai-config according to provider instructions.
