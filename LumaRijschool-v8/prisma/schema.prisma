  id                  String   @id @default(cuid())
  userId              String
  secretAchievementId String
  secretAchievement   SecretAchievement @relation(fields: [secretAchievementId], references: [id])
  discoveredAt        DateTime @default(now())

  @@unique([userId, secretAchievementId])
  @@index([userId])
}

model XPBoostPurchase {
  id          String   @id @default(cuid())
  userId      String
  type        String   // 2X_24H | 2X_7D | 3X_24H
  multiplier  Float    @default(2.0)
  costXp      Int
  startsAt    DateTime @default(now())
  endsAt      DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model VideoQualityPreference {
  userId      String   @id
  preferredQuality String @default("AUTO") // AUTO | 360P | 720P | 1080P
  autoContinue Boolean @default(true)
  pipEnabled  Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}