// LumaRijschool — Production Prisma Schema (PostgreSQL)
// Dutch driving theory platform with gamification, AI tutor, CBR exams, payments, admin, referrals, security.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════
// USERS & AUTH
// ════════════════════════════════════════════════

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  phone         String?
  passwordHash  String
  role          String   @default("STUDENT") // STUDENT | ADMIN | SUPPORT
  country       String   @default("NL")
  device        String?
  avatarUrl     String?
  examDate      DateTime?
  studyGoal     String?
  dailyGoalMin  Int      @default(30)
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?
  lastLoginIp   String?
  banned        Boolean  @default(false)
  referralCode  String   @unique @default(cuid())
  referredById  String?

  accounts        Account[]
  sessions        Session[]
  subscription    Subscription?
  progress        LessonProgress[]
  examAttempts    ExamAttempt[]
  answers         Answer[]
  xpEvents        XPEvent[]
  badges          UserBadge[]
  achievements    UserAchievement[]
  notifications   Notification[]
  payments        Payment[]
  studyPlan       StudyPlan?
  streak          Streak?
  tutorSessions   TutorSession[]
  dailyGoals      DailyGoal[]
  auditLogs       AuditLog[]
  twoFactor       TwoFactorSecret?
  trustedDevices  TrustedDevice[]
  referralsMade   Referral[]      @relation("Referrer")
  referralsReceived Referral[]    @relation("referralsReceived")
  referralRewards ReferralReward[]
  mysteryBoxes    UserMysteryBox[]
  dailyRewards    DailyRewardClaim[]
  seasonPass      UserSeasonPass[]
  challenges      UserChallenge[]
  supportTickets  SupportTicket[]  @relation("TicketAuthor")
  ticketReplies   SupportTicketReply[]
  supportAttachments SupportTicketAttachment[]
  bookmarks       Bookmark[]
  videoProgress   VideoProgress[]
  guest           Guest?
  chatMemberships ChatRoomMember[]
  chatMessages    ChatMessage[]
  lessonComments  LessonComment[]
  lessonRatings   LessonRating[]

  @@index([role])
  @@index([createdAt])
  @@index([referredById])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TwoFactorSecret {
  userId    String  @id
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret    String
  backupCodes String // @default([])
  enabled   Boolean @default(false)
  enabledAt DateTime?
  createdAt DateTime @default(now())
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceFingerprint String
  userAgent String
  ip        String
  lastSeen  DateTime @default(now())
  trustedAt DateTime @default(now())

  @@unique([userId, deviceFingerprint])
  @@index([userId])
}

model IpBlock {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String
  blockedAt DateTime @default(now())
  blockedBy String?
  expiresAt DateTime?
}

// ════════════════════════════════════════════════
// GUEST TRACKING
// ════════════════════════════════════════════════

model Guest {
  id              String   @id @default(cuid())
  // Optional link to user once they register
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  fingerprint     String   @unique
  ip              String
  country         String?
  city            String?
  device          String?
  browser         String?
  os              String?
  referrerUrl     String?
  landingPage     String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  lessonsViewed   String // @default([])
  examsStarted    String // @default([])
  pagesVisited    Int      @default(0)
  timeSpentSec    Int      @default(0)
  aiQuestionsUsed Int      @default(0)
  converted       Boolean  @default(false)
  convertedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  pageViews       PageView[]

  @@index([ip])
  @@index([converted])
  @@index([createdAt])
}

model PageView {
  id        String   @id @default(cuid())
  guestId   String
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  path      String
  duration  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([guestId])
  @@index([createdAt])
}

// ════════════════════════════════════════════════
// CURRICULUM — TOPICS, LESSONS, QUESTIONS
// ════════════════════════════════════════════════

model Topic {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameEn      String?
  color       String   @default("#2563EB")
  iconKey     String?
  imageUrl    String?
  order       Int      @default(0)
  description String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt

  lessons         Lesson[]
  questions       Question[]
  categoryScores  CategoryScore[]

  @@index([order])
  @@index([isPublished])
}

model Lesson {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  order       Int      @default(0)
  summary     String
  description String
  videoUrl    String
  thumbnailUrl String?
  durationSec Int      @default(0)
  isFree      Boolean  @default(false)
  isPublished Boolean  @default(true)
  transcript  String?
  notes       String?
  // Video metadata
  subtitleUrl String?
  // VTT subtitle file URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress      LessonProgress[]
  videoProgress VideoProgress[]
  questions     Question[]
  chapters      Chapter[]
  bookmarks     Bookmark[]

  @@index([topicId])
  @@index([order])
  @@index([isFree])
}

model Chapter {
  id        String  @id @default(cuid())
  lessonId  String
  lesson    Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  startSec  Int
  endSec    Int
  order     Int     @default(0)

  @@index([lessonId])
}

model VideoProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  positionSec Int      @default(0)
  durationSec Int      @default(0)
  completed   Boolean  @default(false)
  speed       Float    @default(1.0)
  updatedAt   DateTime? @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model Bookmark {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  positionSec Int
  label       String?
  createdAt   DateTime @default(now())

  @@index([userId, lessonId])
}

model Question {
  id           String   @id @default(cuid())
  topicId      String
  topic        Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  lessonId     String?
  lesson       Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  // Extended question types
  type         String   @default("SINGLE") // SINGLE | MULTI | IMAGE | VIDEO | HOTSPOT | DRAG_DROP | TRUE_FALSE | CASE_STUDY
  difficulty   String   @default("MEDIUM") // EASY | MEDIUM | HARD
  stem         String
  scenarioText String?
  imageUrl     String?
  videoUrl     String?
  // For HOTSPOT: JSON with target zones on the image
  hotspotZones String?
  // For DRAG_DROP: JSON with items and target slots
  dragDropData String?
  // For CASE_STUDY: longer scenario followed by sub-questions
  caseStudyText String?
  explanation  String
  aiExplanation String?
  isFree       Boolean  @default(false)
  isPublished  Boolean  @default(true)
  tags         String // @default([])
  createdAt    DateTime @default(now())

  options      QuestionOption[]
  answers      Answer[]
  examLinks    ExamQuestion[]

  @@index([topicId])
  @@index([lessonId])
  @@index([difficulty])
  @@index([type])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  key        String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)
  // For HOTSPOT: x,y coordinates
  hotspotX   Int?
  hotspotY   Int?
  // For DRAG_DROP: target slot identifier
  slotId     String?

  @@unique([questionId, key])
  @@index([questionId])
}

// ════════════════════════════════════════════════
// EXAMS — CBR-STYLE MOCK EXAMS (with multiple types)
// ════════════════════════════════════════════════

model Exam {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String
  durationSec  Int      @default(2700)
  passingScore Float    @default(0.875)
  questionCount Int     @default(40)
  isFree       Boolean  @default(false)
  isPublished  Boolean  @default(true)
  tags         String // @default([])
  // Exam types
  type         String   @default("MOCK") // PRACTICE | MOCK | REAL | CUSTOM
  createdAt    DateTime @default(now())

  questions    ExamQuestion[]
  attempts     ExamAttempt[]

  @@index([isFree])
  @@index([type])
}

model ExamQuestion {
  id         String  @id @default(cuid())
  examId     String
  exam       Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int     @default(0)

  @@unique([examId, questionId])
  @@index([examId])
  @@index([questionId])
}

model ExamAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  durationSec Int      @default(0)
  score       Float    @default(0)
  correctCount Int     @default(0)
  totalQuestions Int   @default(40)
  passed      Boolean  @default(false)
  status      String   @default("IN_PROGRESS") // IN_PROGRESS | PAUSED | COMPLETED | ABANDONED
  xpAwarded   Int      @default(0)
  readinessDelta Float @default(0)
  // Pause/resume support
  pausedAt    DateTime?
  resumedAt   DateTime?
  pauseCount  Int      @default(0)
  // Retry tracking
  isRetry     Boolean  @default(false)
  parentAttemptId String?

  answers     Answer[]

  @@index([userId])
  @@index([examId])
  @@index([finishedAt])
  @@index([status])
}

model Answer {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptId    String?
  attempt      ExamAttempt? @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  selectedKeys String // @default([])
  isCorrect    Boolean  @default(false)
  timeMs       Int      @default(0)
  marked       Boolean  @default(false)
  flagged      Boolean  @default(false)
  // For hotspot: stored x,y coords
  hotspotAnswer String?
  // For drag_drop: JSON mapping
  dragDropAnswer String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([questionId])
  @@index([attemptId])
}

// ════════════════════════════════════════════════
// PROGRESS & GAMIFICATION
// ════════════════════════════════════════════════

model LessonProgress {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status       String   @default("NOT_STARTED")
  watchSec     Int      @default(0)
  positionSec  Int      @default(0)
  notesPrivate String?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([status])
}

model XPEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  reason      String
  refId       String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Streak {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  current      Int      @default(0)
  longest      Int      @default(0)
  lastActiveAt DateTime?
  updatedAt    DateTime @updatedAt
}

model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  iconKey     String
  color       String   @default("#2563EB")
  requirement String
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model Achievement {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String
  iconKey      String
  tier         String   @default("BRONZE")
  goalValue    Int
  metric       String
  xpReward     Int      @default(0)
  createdAt    DateTime @default(now())

  users        UserAchievement[]
}

model UserAchievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  unlockedAt  DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

model CategoryScore {
  id         String   @id @default(cuid())
  userId     String
  topicId    String
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  correct    Int      @default(0)
  total      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([userId, topicId])
  @@index([userId])
}

model DailyGoal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  lessonsGoal Int      @default(2)
  lessonsDone Int      @default(0)
  questionsGoal Int    @default(15)
  questionsDone Int    @default(0)
  examGoal    Int      @default(0)
  examDone    Int      @default(0)
  xpEarned    Int      @default(0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Ranks (Bronze → Legend) ────────────────────
model Rank {
  id          Int      @id @default(autoincrement())
  tier        String   @unique // BRONZE | SILVER | GOLD | PLATINUM | DIAMOND | MASTER | LEGEND
  name        String
  minXp       Int
  color       String
  iconKey     String
  perks       String   // JSON description
  createdAt   DateTime @default(now())
}

// ─── Mystery Boxes ──────────────────────────────
model MysteryBox {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  iconKey     String
  color       String
  // Probabilistic contents: [{ type: 'XP', amount: 50, chance: 0.7 }, { type: 'BADGE', slug: 'LUCKY', chance: 0.05 }, ...]
  contents    String   // JSON
  costXp      Int      @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  claims      UserMysteryBox[]
}

model UserMysteryBox {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boxId      String
  box        MysteryBox @relation(fields: [boxId], references: [id])
  rewardType String
  rewardAmount Int
  rewardMeta String?
  openedAt   DateTime @default(now())

  @@index([userId])
}

// ─── Daily Rewards (7-day cycle) ────────────────
model DailyRewardClaim {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayNumber  Int      // 1..7
  xpReward   Int
  claimedAt  DateTime @default(now())

  @@index([userId])
}

// ─── Season Pass ────────────────────────────────
model SeasonPass {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  users       UserSeasonPass[]
}

model UserSeasonPass {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  seasonPassId String
  seasonPass  SeasonPass @relation(fields: [seasonPassId], references: [id])
  xp          Int      @default(0)
  level       Int      @default(1)
  claimedRewards String // @default([])
  updatedAt   DateTime @updatedAt

  @@unique([userId, seasonPassId])
  @@index([userId])
}

// ─── Challenges (Weekly / Monthly) ──────────────
model Challenge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  type        String   // WEEKLY | MONTHLY | DAILY
  metric      String   // LESSONS | EXAMS | XP | PERFECTS | STREAK
  goalValue   Int
  xpReward    Int
  badgeSlug   String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  users       UserChallenge[]
}

model UserChallenge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  claimedAt   DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, challengeId])
  @@index([userId])
}

// ════════════════════════════════════════════════
// SUBSCRIPTIONS & PAYMENTS (STRIPE)
// ════════════════════════════════════════════════

model Plan {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  priceCents  Int
  currency    String   @default("EUR")
  durationDays Int
  stripePriceId String?
  features    String
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  status      String   @default("ACTIVE")
  startedAt   DateTime @default(now())
  expiresAt   DateTime
  autoRenew   Boolean  @default(true)
  stripeSubscriptionId String?
  cancelledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([expiresAt])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  amountCents Int
  currency    String   @default("EUR")
  status      String   @default("PENDING")
  method      String   @default("STRIPE")
  stripeSessionId String?
  stripePaymentIntentId String?
  invoiceUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ════════════════════════════════════════════════
// REFERRAL SYSTEM
// ════════════════════════════════════════════════

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId  String   @unique
  referred    User     @relation("referralsReceived", fields: [referredId], references: [id], onDelete: Cascade)
  code        String
  rewardGiven Boolean  @default(false)
  rewardType  String?  // XP | DAYS | BADGE
  rewardAmount Int     @default(0)
  convertedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

model ReferralReward {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // XP | DAYS | BADGE
  amount      Int
  reason      String   // FRIEND_JOINED | FRIEND_SUBSCRIBED | FRIEND_7_DAY | FRIEND_30_DAY
  referralId  String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ════════════════════════════════════════════════
// STUDY PLANNER
// ════════════════════════════════════════════════

model StudyPlan {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examDate    DateTime
  dailyMinutes Int     @default(30)
  questionsPerDay Int  @default(15)
  examsPerWeek  Int    @default(2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  days        PlanDay[]
}

model PlanDay {
  id          String   @id @default(cuid())
  planId      String
  plan        StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  date        DateTime
  title       String
  lessonsGoal Int      @default(0)
  questionsGoal Int    @default(0)
  examGoal    Int      @default(0)
  isRest      Boolean  @default(false)
  lessonsDone Int      @default(0)
  questionsDone Int    @default(0)
  examDone    Int      @default(0)
