# LumaRijschool — Environment Variables
# Copy to .env and fill in real values for production.

# ─── Core ────────────────────────────────────────────────
NODE_ENV=production
NEXTAUTH_URL=https://lumatheorie.nl
NEXTAUTH_SECRET=change-me-to-a-strong-random-string-64chars

# ─── Database (PostgreSQL) ───────────────────────────────
DATABASE_URL="postgresql://luma:luma_password@localhost:5432/lumarijschool?schema=public"

# ─── Redis ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Stripe (REAL ONLY — no mock mode) ──────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_WEEK=
STRIPE_PRICE_MONTH=

# ─── SMTP / Email ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LumaRijschool <noreply@lumatheorie.nl>"

# ─── AI Tutor (uses z-ai-web-dev-sdk, no extra key needed) ─
ZAI_API_KEY=

# ─── WebSockets (Socket.io mini-service) ─────────────────
WS_PORT=3001

# ─── App ─────────────────────────────────────────────────
APP_NAME=LumaRijschool
APP_URL=https://lumatheorie.nl
SUPPORT_EMAIL=support@lumatheorie.nl

# ─── Backup ──────────────────────────────────────────────
BACKUP_DIR=/var/backups/lumarijschool
BACKUP_RETENTION_DAYS=30

# ─── AWS S3 (optional offsite backups) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=

# ─── Security ────────────────────────────────────────────
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
CLOUDFLARE_MODE=false

# ─── Monitoring (optional) ───────────────────────────────
SENTRY_DSN=

# ─── Web Push (optional) ─────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@lumatheorie.nl
