FROM nginx:alpine

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy both HTTP-only and SSL nginx configs
COPY nginx-http.conf /etc/nginx/nginx-http.conf
COPY nginx-ssl.conf /etc/nginx/nginx-ssl.conf

# Copy startup script
COPY nginx-entrypoint.sh /docker-entrypoint.d/99-auto-ssl.sh
RUN chmod +x /docker-entrypoint.d/99-auto-ssl.sh

# Certs directory (will be empty by default)
RUN mkdir -p /etc/nginx/certs